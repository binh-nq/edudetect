# Set default behaviour, in case users don't have core.autocrlf set.
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.py text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Bash and Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows specific
*.bat text eol=crlf
*.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.pt binary
*.pth binary
*.bin binary
*.safetensors binary
*.onnx binary
